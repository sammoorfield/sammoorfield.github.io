{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A VFX project containing multiple shots",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Project name" },
        "description": { "type": "string", "description": "Project details" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" },
        "ownerId": { "type": "string", "description": "User ID of the project owner" }
      },
      "required": ["name", "createdAt", "ownerId"]
    },
    "Shot": {
      "title": "Shot",
      "description": "An individual VFX shot within a project",
      "type": "object",
      "properties": {
        "turnover": { "type": "string", "description": "Turnover identifier (e.g. T001)" },
        "name": { "type": "string", "description": "Shot name (e.g. KHS_001_001)" },
        "version": { "type": "integer", "description": "Shot version number" },
        "thumbnail": { "type": "string", "description": "Base64 encoded thumbnail image or URL" },
        "status": { "type": "string", "enum": ["ACTIVE", "IN PROGRESS", "RENDER", "DELIVERED (DRAFT)", "APPROVED (DRAFT)", "DELIVERED (FINAL)", "ON HOLD", "CANCELLED"], "description": "Current status of the shot" },
        "alert": { "type": "string", "description": "Alert message or warning" },
        "startDate": { "type": "string", "format": "date-time", "description": "Schedule start date" },
        "endDate": { "type": "string", "format": "date-time", "description": "Schedule end date" },
        "projectId": { "type": "string", "description": "Reference to the parent project" }
      },
      "required": ["turnover", "name", "version", "status", "startDate", "endDate", "projectId"]
    },
    "Task": {
      "title": "Task",
      "description": "A progress task associated with a shot",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Task description" },
        "isCompleted": { "type": "boolean", "description": "Completion status" },
        "shotId": { "type": "string", "description": "Reference to the parent shot" }
      },
      "required": ["title", "isCompleted", "shotId"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Collection of tracks VFX projects"
    },
    "/projects/{projectId}/shots/{shotId}": {
      "schema": "Shot",
      "description": "Shots belonging to a specific project"
    },
    "/projects/{projectId}/shots/{shotId}/tasks/{taskId}": {
      "schema": "Task",
      "description": "Tasks for a specific shot"
    }
  }
}
